# Drizzle
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# Hack Club Auth — register an OAuth app at https://auth.hackclub.com/developer/apps
# ("app me up!"). Add your redirect URI(s) there (localhost is allowed for dev).
# Scopes requested: openid profile email name slack_id verification_status.
# (birthdate/address are HQ-restricted and NOT requested — see src/routes/login.)
HCA_CLIENT_ID=""
HCA_CLIENT_SECRET=""
HCA_REDIRECT_URI=""   # e.g. https://boba.hackclub.com/auth/callback

# Slack (needs users:read scope)
SLACK_BOT_TOKEN=""
# Channel builders are invited to on a hard project approval. Leave blank to disable.
# The bot must be a member of this channel and have the invite scope (channels:write / groups:write).
SLACK_APPROVED_CHANNEL_ID=""
# Channel new builders are auto-invited to on first login. Defaults to C0AM132QQUR.
SLACK_WELCOME_CHANNEL_ID=""
# Slack USER token (xoxp-…) used by the admin mass-DM tool so DMs come from a real
# account. Needs chat:write + im:write user scopes. Leave blank to disable the tool.
SLACK_USER_TOKEN=""
# Channel reviewers watch for new project submissions/ships. The bot must be a
# member of this channel. Defaults to C0BBHACUXE1 if left blank.
SLACK_REVIEW_CHANNEL_ID=""

# Token encryption key for AES-256-GCM (generate with: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=""

# GitHub OAuth — register an OAuth app at https://github.com/settings/developers
# ("New OAuth App"). Authorization callback URL = {origin}/auth/github/callback.
# Used to push a builder's site to a repo in THEIR account + enable GitHub Pages
# (scope: public_repo). Token stored encrypted (TOKEN_ENCRYPTION_KEY).
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI=""   # e.g. https://boba.hackclub.com/auth/github/callback

# Hackatime OAuth
HACKATIME_CLIENT_ID=""
HACKATIME_CLIENT_SECRET=""
# Optional: defaults to {origin}/auth/hackatime/callback
HACKATIME_REDIRECT_URI=""

# Space-separated HCA sub (ident! tag) IDs
ADMIN_IDS=""
REVIEWER_IDS=""

# Hack Club CDN (https://cdn.hackclub.com)
CDN_API_KEY=""

# Staging mode: when "true"/"1"/"yes", skips writes to external systems (e.g. Airtable)
# so a non-prod instance can't leak test data into real records.
STAGING=""